#include <iostream>

using namespace std;

string numberToWord(int n)
{
	if (n == 0 )
	{
		return "ZERO";
	}

	if(n%20 != 0)
	{


		switch(n%20)
		{		
			case 1:
				return "ONE";
				break;
			case 2:
				return "TWO";
				break;
			case 3:
				return "THREE";
				break;
			case 4:
				return "FOUR";
				break;
			case 5:
				return "FIVE";
				break;
			case 6:
				return "SIX";
				break;
			case 7:
				return "SEVEN";
				break;
			case 8:
				return "EIGHT";
				break;
			case 9:
				return "NINE";
				break;
			case 10:
				return "TEN";
				break;
			case 11:
				return "ELEVEN";
				break;
			case 12:
				return "TWELVE";
				break;
			case 13:
				return "THRTEEN";
				break;
			case 14:
				return "FOURTEEN";
				break;
			case 15:
				return "FIFTEEN";
				break;
			case 16:
				return "SIXTEEN";
				break;
			case 17:
				return "SEVENTEEN";
				break;
			case 18:
				return "EIGHTEEN";
				break;
			case 19:
				return "NINETEEN";
				break;
			default:
				return "Defaul";
		}
	}







	return "NUMBER";
}

int main()
{
	int n;
	cout<<"Enter -1 to close the loop\n";
	while (n != -1)
	{
		cout<<"Enter the number : ";

		cin>>n;

		if(n<0 ||  n> 100000000) // n<0 -> n should not be negative
		{
			cout<<"Number is out of range\n";
			return 0;
		}

		cout<<"In the words 	 : "<<numberToWord(n)<<endl;
//		cout<<"Enter -1 to close the loop\n\n";
	}
	return 0;
}
